<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ledger.mapper.BillMapper">
  <resultMap id="BaseResultMap" type="com.ledger.entity.Bill">
    <!--@mbg.generated-->
    <!--@Table bill-->
    <id column="id" jdbcType="BIGINT" property="id" />
    <result column="transaction_date" jdbcType="DATE" property="transactionDate" />
    <result column="transaction_time" jdbcType="TIME" property="transactionTime" />
    <result column="income_amount" jdbcType="DECIMAL" property="incomeAmount" />
    <result column="expense_amount" jdbcType="DECIMAL" property="expenseAmount" />
    <result column="amount_type" jdbcType="VARCHAR" property="amountType" />
    <result column="transaction_type" jdbcType="VARCHAR" property="transactionType" />
    <result column="transaction_desc" jdbcType="VARCHAR" property="transactionDesc" />
    <result column="payment_channel" jdbcType="VARCHAR" property="paymentChannel" />
    <result column="category" jdbcType="VARCHAR" property="category" />
    <result column="sub_category" jdbcType="VARCHAR" property="subCategory" />
    <result column="manual_remark" jdbcType="VARCHAR" property="manualRemark" />
    <result column="include_in_statistics" jdbcType="VARCHAR" property="includeInStatistics" />
    <result column="manual_entry" jdbcType="VARCHAR" property="manualEntry" />
    <result column="data_hash" jdbcType="VARCHAR" property="dataHash" />
    <result column="creator_code" jdbcType="VARCHAR" property="creatorCode" />
    <result column="updater_code" jdbcType="VARCHAR" property="updaterCode" />
    <result column="creator_name" jdbcType="VARCHAR" property="creatorName" />
    <result column="updater_name" jdbcType="VARCHAR" property="updaterName" />
    <result column="create_time" jdbcType="TIMESTAMP" property="createTime" />
    <result column="update_time" jdbcType="TIMESTAMP" property="updateTime" />
    <result column="deleted" jdbcType="VARCHAR" property="deleted" />
  </resultMap>
  <sql id="Base_Column_List">
    <!--@mbg.generated-->
    id, transaction_date, transaction_time, income_amount, expense_amount, amount_type, 
    transaction_type, transaction_desc, payment_channel, category, sub_category, manual_remark, 
    include_in_statistics, manual_entry, data_hash, creator_code, updater_code, creator_name, 
    updater_name, create_time, update_time, deleted
  </sql>
  
  <!-- 公共查询条件 -->
  <sql id="Common_Where_Clause">
    <where>
        deleted = '0'
        
        <!-- 交易类型 -->
        <if test="dto.transactionType != null and dto.transactionType != ''">
            AND transaction_type = #{dto.transactionType}
        </if>
        
        <!-- 分类 -->
        <if test="dto.category != null and dto.category != ''">
            AND category = #{dto.category}
        </if>
        
        <!-- 二级分类 -->
        <if test="dto.subCategory != null and dto.subCategory != ''">
            AND sub_category = #{dto.subCategory}
        </if>
        
        <!-- 支付渠道 -->
        <if test="dto.paymentChannel != null and dto.paymentChannel != ''">
            AND payment_channel = #{dto.paymentChannel}
        </if>
        
        <!-- 手工记账 -->
        <if test="dto.manualEntry != null and dto.manualEntry != ''">
            AND manual_entry = #{dto.manualEntry}
        </if>
        
        <!-- 是否计入统计 -->
        <if test="dto.includeInStatistics != null and dto.includeInStatistics != ''">
            AND include_in_statistics = #{dto.includeInStatistics}
        </if>
        
        <!-- 收支类型 -->
        <if test="dto.amountType != null and dto.amountType != ''">
            AND amount_type = #{dto.amountType}
        </if>
        
        <!-- 关键词搜索（交易描述或用户备注） -->
        <if test="dto.keywords != null and dto.keywords != ''">
            AND (
                transaction_desc LIKE CONCAT('%', #{dto.keywords}, '%')
                OR manual_remark LIKE CONCAT('%', #{dto.keywords}, '%')
            )
        </if>
        
        <!-- 最小金额 -->
        <if test="dto.minAmount != null">
            AND income_amount &gt;= #{dto.minAmount}
        </if>
        
        <!-- 最大金额 -->
        <if test="dto.maxAmount != null">
            AND income_amount &lt;= #{dto.maxAmount}
        </if>
        
        <!-- 开始日期 -->
        <if test="dto.startDate != null">
            AND transaction_date &gt;= #{dto.startDate}
        </if>
        
        <!-- 结束日期 -->
        <if test="dto.endDate != null">
            AND transaction_date &lt;= #{dto.endDate}
        </if>
    </where>
  </sql>

    <!-- 分页查询账单列表 -->
    <select id="selectBillPage" resultMap="BaseResultMap">
        SELECT
            <include refid="Base_Column_List" />
        FROM bill
        <include refid="Common_Where_Clause" />
        ORDER BY transaction_date DESC, transaction_time DESC
    </select>
    
    <!-- 查询统计数据 -->
    <select id="getStatistics" resultType="com.ledger.vo.BillStatisticsVO">
        SELECT
            COALESCE(SUM(CASE WHEN amount_type = 'INCOME' THEN income_amount ELSE 0 END), 0) AS totalIncome,
            COALESCE(SUM(CASE WHEN amount_type = 'EXPENSE' THEN expense_amount ELSE 0 END), 0) AS totalExpense
        FROM bill
        <include refid="Common_Where_Clause" />
    </select>

</mapper>
